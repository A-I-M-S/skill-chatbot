# wa-bridge env (loaded via dotenv). Copy to .env, fill in, never commit.

# HTTP control surface (orchestrator -> bridge).
WA_BRIDGE_PORT=7788
WA_BRIDGE_TOKEN=

# Baileys auth state dir (gitignored). Keep absolute for systemd.
WA_AUTH_DIR=/root/.openclaw/workspace/dev/projects/skill-chatbot/wa-bridge/auth_info

# NDJSON inbox written for the orchestrator to tail.
INBOX_PATH=/root/.openclaw/workspace/dev/projects/skill-chatbot/wa-bridge/inbox.ndjson

# Outbound queue the sender drains.
OUTBOX_PATH=/root/.openclaw/workspace/dev/projects/skill-chatbot/wa-bridge/queue/outbound.jsonl

# Log level for pino (trace|debug|info|warn|error|fatal).
LOG_LEVEL=info

# Reconnect tuning (#2 will surface in /status).
WA_RECONNECT_MAX_BACKOFF_MS=60000
WA_RECONNECT_GIVEUP_QR=4

# Image handling (#10). Inbound images are downloaded to <RAG_PHOTOS_DIR>/inbound/.
# Larger images are silently dropped from the line (text/caption is still kept).
RAG_PHOTOS_DIR=/root/rag-photos
MAX_IMAGE_BYTES=10485760
