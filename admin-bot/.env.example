# admin-bot env (loaded via python-dotenv). Copy to .env, fill in, never commit.

# ─── orchestrator admin API base ────────────────────────────────────────────
# Full URL of the orchestrator's admin sub-app, INCLUDING the trailing /admin.
# The orchestrator's HTTP server (ORCHESTRATOR_PORT, default 7789) mounts the
# admin sub-app at /admin/* — see orchestrator/README.md.
# Examples:
#   http://127.0.0.1:7789/admin                  # orchestrator on the same host
#   http://10.0.0.5:7789/admin                  # orchestrator on a LAN box
ADMIN_API_BASE=http://127.0.0.1:7789/admin

# ─── shared with orchestrator (issue #30) ──────────────────────────────────
# Must equal the orchestrator's ADMIN_HTTP_TOKEN. Empty token disables the
# admin sub-app entirely (every call returns 401 admin_disabled).
ADMIN_HTTP_TOKEN=

# ─── admin allowlist (defense-in-depth) ─────────────────────────────────────
# Comma-separated Telegram user ids allowed to run admin commands.
# Same set as the orchestrator's ADMIN_TELEGRAM_IDS. The skill refuses
# non-admin senders locally before calling the API; the orchestrator
# re-checks the same set on the server side.
ADMIN_TELEGRAM_IDS=