#!/usr/bin/env python3
"""`/bookings [YYYY-MM-DD]` — admin-bot side.

Calls ``GET /admin/bookings?date=…`` on the orchestrator. With no date
the script prints the prompt and saves state so the next message from
the same sender is treated as the date.
"""
from __future__ import annotations

import re
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from _lib import (  # noqa: E402
    api_call,
    die,
    format_event_list,
    load_env,
    parse_sender_id,
    require_admin,
    state_clear,
    state_get,
    state_set,
)

_DATE_RE = re.compile(r"^\d{4}-\d{2}-\d{2}$")


def main(argv: list[str]) -> int:
    sender_id, rest = parse_sender_id(argv)
    settings = load_env()
    require_admin(sender_id, settings)

    if not rest:
        # Prompt-and-wait. The next message from this sender must be
        # routed back through bookings with the date as a single arg.
        prev = state_get(sender_id)
        if prev.get("awaiting_date"):
            # Adapter bug — clear and re-prompt.
            state_clear(sender_id)
        state_set(sender_id, {"awaiting_date": True})
        print("Which date? (YYYY-MM-DD)")
        return 0

    date_str = rest[0]
    if not _DATE_RE.match(date_str):
        die(f"Bad date: expected YYYY-MM-DD (got {date_str!r})")
    state_clear(sender_id)

    status, body = api_call(
        settings, sender_id, "GET", "bookings",
        query={"date": date_str, "tz": "Asia/Singapore"},
    )
    if status != 200 or not isinstance(body, dict):
        die(f"Bookings lookup failed ({status}): {body}", code=1)

    events = body.get("events") or []
    print(format_event_list(date_str, events))
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
