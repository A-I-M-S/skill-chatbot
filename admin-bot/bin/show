#!/usr/bin/env python3
"""`/show access [source]` — admin-bot side.

Calls ``GET /admin/show`` (optionally ``?source=…``) on the orchestrator.
"""
from __future__ import annotations

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from _lib import api_call, die, format_acl_table, load_env, parse_sender_id, require_admin  # noqa: E402


def main(argv: list[str]) -> int:
    sender_id, rest = parse_sender_id(argv)
    if not rest:
        die("Usage: show --sender-id <int> access [source]")
    if rest[0] != "access":
        die(f"Unknown show subcommand: {rest[0]!r} (only 'access' is supported)")
    source_filter = rest[1] if len(rest) > 1 else None

    settings = load_env()
    require_admin(sender_id, settings)

    query = {"source": source_filter} if source_filter else None
    status, body = api_call(settings, sender_id, "GET", "show", query=query)
    if status != 200 or not isinstance(body, dict):
        die(f"Show failed ({status}): {body}", code=1)

    rows = body.get("rows") or []
    print(format_acl_table(rows))
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
