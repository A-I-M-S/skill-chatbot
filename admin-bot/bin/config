#!/usr/bin/env python3
"""`/config <key> <value>` — admin-bot side.

Calls ``PATCH /admin/config`` on the orchestrator. Value is passed as
a JSON literal so callers can pass ints, lists, and objects:
``/config slot_duration_minutes 90``            → 90
``/config blackout_dates '["2026-12-25"]'``     → ["2026-12-25"]
"""
from __future__ import annotations

import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from _lib import api_call, die, load_env, parse_sender_id, require_admin  # noqa: E402


def _coerce(value: str):
    """Best-effort JSON decode; falls back to raw string."""
    try:
        return json.loads(value)
    except (ValueError, TypeError):
        return value


def main(argv: list[str]) -> int:
    sender_id, rest = parse_sender_id(argv)
    if len(rest) < 2:
        die("Usage: config --sender-id <int> <key> <value>")
    key, raw_value = rest[0], " ".join(rest[1:])

    settings = load_env()
    require_admin(sender_id, settings)

    status, body = api_call(
        settings, sender_id, "PATCH", "config",
        body={"key": key, "value": _coerce(raw_value)},
    )
    if status != 200 or not isinstance(body, dict):
        msg = body if isinstance(body, str) else json.dumps(body, ensure_ascii=False)
        die(f"Config patch failed ({status}): {msg}", code=1)
    print(f"Patched `{key}` in `booking_rules.yaml`.")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
