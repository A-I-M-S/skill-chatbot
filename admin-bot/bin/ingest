#!/usr/bin/env python3
"""`/ingest <path>` — admin-bot side.

Calls ``POST /admin/ingest`` on the orchestrator. See
``admin-bot/SKILL.md`` for the full command spec.
"""
from __future__ import annotations

import sys
from pathlib import Path

# Make the sibling _lib importable regardless of CWD.
sys.path.insert(0, str(Path(__file__).resolve().parent))

from _lib import api_call, die, load_env, parse_sender_id, require_admin  # noqa: E402


def main(argv: list[str]) -> int:
    sender_id, rest = parse_sender_id(argv)
    if not rest:
        die("Usage: ingest --sender-id <int> <path-to-file>")
    path = rest[0]
    p = Path(path)

    settings = load_env()
    require_admin(sender_id, settings)

    # Admin check first — don't leak file existence to non-admins.
    if not p.exists():
        die(f"File not found: {path}")

    # Pick source_type from extension. The orchestrator also accepts
    # an explicit override via "md:" / "pdf:" prefix on the path.
    src_path = path
    source_type = "path"
    if path.startswith("md:"):
        source_type = "md"
        src_path = path[len("md:"):]
    elif path.startswith("pdf:"):
        source_type = "pdf"
        src_path = path[len("pdf:"):]
    elif p.suffix.lower() == ".md":
        source_type = "md"
    elif p.suffix.lower() == ".pdf":
        source_type = "pdf"

    status, body = api_call(
        settings, sender_id, "POST", "ingest",
        body={"source_type": source_type, "target": src_path},
    )
    if status != 200 or not isinstance(body, dict):
        die(f"Ingest failed ({status}): {body}", code=1)

    chunks = body.get("chunks", "?")
    acl = body.get("acl", {})
    scope = "public" if acl.get("public") else f"admin-only ({len(acl.get('telegram_ids') or [])} id(s))"
    print(f"Ingested *{chunks}* chunk(s) from `{src_path}` into Qdrant (acl: {scope}).")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
