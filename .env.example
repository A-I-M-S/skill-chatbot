# ─── shared with rag-qdrant ───────────────────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=
INFERENCE_BASE_URL=
INFERENCE_API_KEY=
INFERENCE_MODEL=MiniMax-M3
RAG_PHOTOS_DIR=/root/rag-photos
ADMIN_TELEGRAM_IDS=
SEMANTIC_CACHE_ENABLED=1
SEARCH_CACHE_ENABLED=1

# ─── shared with farm-tour-booking ────────────────────────────────────────
COMPOSIO_API_KEY=
COMPOSIO_CONNECTED_ACCOUNT_ID=
COMPOSIO_ENTITY_ID=
BOOKING_RULES_PATH=/root/.openclaw/workspace/admin/skills/farm-tour-booking/config/booking_rules.yaml
PYTHONPATH_BOOKING=/root/.openclaw/workspace/admin/skills/farm-tour-booking/scripts

# ─── whatsapp notify (handoff + new-booking alerts) ───────────────────────
# Small list of E.164 numbers that receive admin alerts (handoff, new booking).
# Comma-separated, no spaces. Default to admin + 1 backup.
# Example: WA_NOTIFY=+60123456789,+60198765432
WA_NOTIFY=
ADMIN_CONTACT_NUMBER=

# ─── wa-bridge ────────────────────────────────────────────────────────────
WA_BRIDGE_PORT=7788
WA_BRIDGE_TOKEN=
# Baileys multi-file auth state. Prod install uses the path below; a dev
# checkout can point this anywhere writable.
WA_AUTH_DIR=/var/lib/skill-chatbot/wa-bridge/auth
# WhatsApp number to (re)link with, used by `npm run auth:code` when no CLI
# arg is given. E.164, no spaces. Set this so re-auth is a single command.
# Example: WA_PAIR_NUMBER=+6591234567
WA_PAIR_NUMBER=

# ─── orchestrator ─────────────────────────────────────────────────────────
ORCHESTRATOR_PORT=7789
ORCHESTRATOR_DB=/root/.openclaw/workspace/dev/projects/skill-chatbot/orchestrator/state.sqlite
INBOX_PATH=/root/.openclaw/workspace/dev/projects/skill-chatbot/wa-bridge/inbox.ndjson
ORCHESTRATOR_LOG=/var/log/skill-chatbot/orchestrator.log
WA_BRIDGE_LOG=/var/log/skill-chatbot/bridge.log
BOOKING_HORIZON_DAYS=90

# ─── image handling (#10) ─────────────────────────────────────────────────
# Inbound images are written by wa-bridge to <RAG_PHOTOS_DIR>/inbound/<sha>.<ext>.
# The orchestrator looks here for the photo when the caption asks about it.
MAX_IMAGE_BYTES=10485760

# ─── admin HTTP sub-app (issue #30) ───────────────────────────────────────
# Defense-in-depth: every /admin/* request must carry BOTH headers below.
# X-Admin-Token must equal ADMIN_HTTP_TOKEN (401 on mismatch).
# X-Admin-Telegram-Id must be one of the ADMIN_TELEGRAM_IDS ints (403 otherwise).
# The same env is checked locally by the admin-bot/ TG skill (#31).
# Leave ADMIN_HTTP_TOKEN empty to disable the sub-app entirely.
ADMIN_HTTP_TOKEN=

# ─── booking rules (#32) ─────────────────────────────────────────────────
# Absolute path to booking_rules.yaml — the source of truth for slot duration,
# operating hours, max capacity, blackout dates, pricing, deposit instructions.
# The orchestrator reads this file on every /admin/config PATCH (ruamel round-trip).
# Default install location (see scripts/install-systemd-system.sh):
#   /etc/skill-chatbot/booking_rules.yaml
# Adjust if you keep it elsewhere.
BOOKING_RULES_PATH=/etc/skill-chatbot/booking_rules.yaml

# ─── install paths (systemd units) ───────────────────────────────────────
# Used by scripts/install-systemd-system.sh — adjust only if you put the
# repo somewhere other than /opt/skill-chatbot.
SKILL_CHATBOT_INSTALL_DIR=/opt/skill-chatbot
SKILL_CHATBOT_USER=skill-chatbot
SKILL_CHATBOT_GROUP=skill-chatbot
