# skill-chatbot — single environment template.
#
# Copy to .env (dev) or /etc/skill-chatbot.env (prod, mode 600) and fill in.
# Grouped by feature. "REQUIRED" vars must be set or the service won't work;
# others have working defaults. See HANDOFF.md for the deploy runbook.

# ─── inference / LLM (router + RAG both read these) ───────────────────────
# OpenAI-compatible chat endpoint (the /v1 chat-completions API — NOT an
# Anthropic-format /anthropic endpoint). Both the orchestrator router and the
# rag_qdrant engine use the SAME vars, so they can't drift.
# MiniMax example: base = https://api.minimax.io/v1 , model = minimax-m3.
# Note: MiniMax-M3 is a reasoning model; its <think> blocks are stripped in
# src/rag.py before any answer is sent to a customer.
INFERENCE_BASE_URL=                 # REQUIRED, OpenAI-compatible, e.g. https://api.minimax.io/v1
INFERENCE_API_KEY=                  # REQUIRED
INFERENCE_MODEL=minimax-m3          # REQUIRED — exact model id your provider expects
INFERENCE_TEMPERATURE=0

# ─── RAG / Qdrant (FAQ answering via skill-rag-qdrant) ────────────────────
# Embeddings are computed locally (FastEmbed) — no embedding endpoint needed.
QDRANT_URL=                         # REQUIRED
QDRANT_API_KEY=                     # REQUIRED
QDRANT_COLLECTION=system_rag        # must match the collection you ingest into
# rag_qdrant FAIL-CLOSES at import if this is empty. Comma-separated Telegram
# admin ids (ints). Also used by the admin HTTP sub-app below.
ADMIN_TELEGRAM_IDS=                 # REQUIRED
RAG_PHOTOS_DIR=/root/rag-photos
# skill-rag-qdrant is not pip-installable; it must be importable as `rag_qdrant`.
# `make orch-install-rag` clones it and makes it importable in the venv. For
# systemd, point PYTHONPATH at the clone (the dir that CONTAINS rag_qdrant/):
# PYTHONPATH=/opt/skill-rag-qdrant

# ─── farm-tour booking (Composio → Outlook calendar) ──────────────────────
COMPOSIO_API_KEY=                   # REQUIRED for booking
# Optional: auto-resolved if exactly one ACTIVE Outlook account is linked.
COMPOSIO_CONNECTED_ACCOUNT_ID=
COMPOSIO_ENTITY_ID=
# Booking rules (operating hours, capacity, blackout dates, deposit). Same
# file that `make ingest-rules` pushes into Qdrant — one source of truth.
BOOKING_RULES_PATH=/etc/skill-chatbot/booking_rules.yaml
# How far ahead new bookings are accepted.
BOOKING_HORIZON_DAYS=90
# The booking CLI defaults to the vendored orchestrator/booking_cli/booking_flow.py.
# Only set this to override with a differently-deployed skill:
# SKILL_FARM_TOUR_BOOKING_PATH=/opt/skill-chatbot/orchestrator/booking_cli/booking_flow.py

# ─── bridge I/O (orchestrator ↔ wa-bridge) ────────────────────────────────
# The orchestrator tails INBOX_PATH (written by wa-bridge) and POSTs replies
# to WA_BRIDGE_URL/send with WA_BRIDGE_TOKEN.
WA_BRIDGE_URL=http://127.0.0.1:7788   # REQUIRED
WA_BRIDGE_TOKEN=                      # REQUIRED — must match wa-bridge's token
INBOX_PATH=/var/lib/skill-chatbot/wa-bridge/inbox.ndjson       # REQUIRED
ORCHESTRATOR_DB=/var/lib/skill-chatbot/orchestrator/state.sqlite  # REQUIRED
ORCHESTRATOR_PORT=7789
ORCHESTRATOR_LOG=/var/log/skill-chatbot/orchestrator.log

# ─── notify / handoff (admin alerts) ──────────────────────────────────────
# E.164 numbers that receive admin alerts (handoff, new booking). Comma list.
# Example: WA_NOTIFY=+60123456789,+60198765432
WA_NOTIFY=
# Number the bot tells customers to call on handoff.
ADMIN_CONTACT_NUMBER=

# ─── admin HTTP sub-app (Telegram admin-bot backend) ──────────────────────
# Every /admin/* request must carry X-Admin-Token (== ADMIN_HTTP_TOKEN) and
# X-Admin-Telegram-Id (one of ADMIN_TELEGRAM_IDS). Leave token empty to disable.
ADMIN_HTTP_TOKEN=

# ─── wa-bridge (WhatsApp gateway) ─────────────────────────────────────────
WA_BRIDGE_PORT=7788
# Baileys multi-file auth state (created by `npm run auth:code`).
WA_AUTH_DIR=/var/lib/skill-chatbot/wa-bridge/auth
# WhatsApp number to (re)link with — used by `npm run auth:code` when no CLI
# arg is given. E.164, no spaces. Example: WA_PAIR_NUMBER=+6591234567
WA_PAIR_NUMBER=
WA_BRIDGE_LOG=/var/log/skill-chatbot/bridge.log
# Inbound images are written by wa-bridge to <RAG_PHOTOS_DIR>/inbound/<sha>.<ext>.
MAX_IMAGE_BYTES=10485760

# ─── install paths (scripts/install-systemd-system.sh) ────────────────────
SKILL_CHATBOT_INSTALL_DIR=/opt/skill-chatbot
SKILL_CHATBOT_USER=skill-chatbot
SKILL_CHATBOT_GROUP=skill-chatbot
